<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>65.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <description>Update Book Status To borrowed after creating or updating the record in borrowing records object</description>
    <environments>Default</environments>
    <interviewLabel>Update Book Status To borrowed {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Update Book Status To borrowed</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <description>When the book is borrowed the book availability status should be changed to borrowed</description>
        <name>Book_Status_Update_to_borrowed</name>
        <label>Book Status Update to borrowed</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.Book__r.Id</elementReference>
            </value>
        </filters>
        <inputAssignments>
            <field>Availability_Status__c</field>
            <value>
                <stringValue>Borrowed</stringValue>
            </value>
        </inputAssignments>
        <object>Book__c</object>
    </recordUpdates>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Book_Status_Update_to_borrowed</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Return_Date__c</field>
            <operator>IsNull</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <object>Borrowing_Record__c</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
